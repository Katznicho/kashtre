APP_ENV=production
APP_DEBUG=false
APP_URL=https://app.yourdomain.com

# Calling service integration
CALLING_SERVICE_URL=https://calling.yourdomain.com
CALLING_SERVICE_SYNC_SECRET=replace_with_the_same_shared_secret

# Reverb broadcasting for caller audio and PA signaling
BROADCAST_DRIVER=reverb
REVERB_SERVER=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_APP_ID=kashtre
REVERB_APP_KEY=replace_with_reverb_key
REVERB_APP_SECRET=replace_with_reverb_secret
REVERB_HOST=reverb.yourdomain.com
REVERB_PORT=443
REVERB_SCHEME=https

# Frontend Echo/Reverb client
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
